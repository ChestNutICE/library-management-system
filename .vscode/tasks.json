{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "安装项目依赖",
      "type": "process",
      "command": "${workspaceFolder}\\.venv312\\Scripts\\python.exe",
      "args": [
        "-m",
        "pip",
        "install",
        "-r",
        "${workspaceFolder}\\requirements.txt"
      ],
      "problemMatcher": []
    },
    {
      "label": "运行测试",
      "type": "process",
      "command": "${workspaceFolder}\\.venv312\\Scripts\\python.exe",
      "args": [
        "-m",
        "pytest",
        "-q"
      ],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
